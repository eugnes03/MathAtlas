  :refs ["def:irreducible" "def:morphism-rep"],
  :latex
  "\\label{thm:schur}\nLet $(V, \\rho)$ and $(W, \\sigma)$ be irreducible $G$-representations (Definition~\\ref{def:irreducible}) over an algebraically closed field, and let $T : V \\to W$ be an intertwiner (Definition~\\ref{def:morphism-rep}).\n\\begin{enumerate}\n  \\item Either $T = 0$ or $T$ is an isomorphism.\n  \\item If $V = W$, then $T = \\lambda\\, \\mathrm{id}_V$ for some $\\lambda \\in k$.\n\\end{enumerate}",
  :type :theorem,
  :title "Schur's Lemma",
  :concepts [],
  :label "thm:schur",
  :id "36e5bd4f",
  :source-file "lie-groups.tex",
  :area "Lie Groups and Lie Algebras",
  :depends-on ["a8ec3e23" "f70e3a35"],
  :created-at "2026-03-27"}
