  "$ \\sqrt{2\\pi}\\int_{-\\infty}^x h(y) \\frac{e^{y^2/2}}{\\sqrt{2\\pi}} - \\mathbb{E}(h(N))\\int_{-/infty}^\\infty \\gamma(dx) = 0$",
  :refs ["def:steinsequation"],
